# AI Agent configuration
# Copy this to ai_agent/.env and fill in values.
# NEVER commit ai_agent/.env to git.

# --- AI provider (pick one) ---
# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (alternative)
# OPENAI_API_KEY=sk-...

# --- Agent behaviour ---
# Set to "false" to allow the agent to actually edit files and commit.
# Defaults to "true" (safe, read-only plan mode).
DRY_RUN=true

# --- Git safety ---
# Branch the agent is allowed to commit to.
# Agent will refuse to run if current branch does not match.
AGENT_BRANCH=ai-agent

# --- Repo path (defaults to directory above ai_agent/) ---
# REPO_ROOT=/path/to/repo
