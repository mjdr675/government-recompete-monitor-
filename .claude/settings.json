{
  "permissions": {
    "allow": [
      "Bash(venv/bin/pytest tests/ -v)",
      "Bash(venv/bin/pytest tests/ -q)",
      "Bash(venv/bin/pytest *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/gate_guard.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/session_handoff.py\""
          }
        ]
      }
    ]
  }
}
